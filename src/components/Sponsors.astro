---
import { Image } from 'astro:assets';

const sponsors = [
  {
    href: 'https://stcroixrods.com/',
    label: 'St. Croix Rods website',
    img: 'https://images.prismic.io/alexprieu/e544fc20-1c66-43a5-b2a9-09dd565b29c5_st._croix_rods_vcjkbs.png?auto=compress,format',
    alt: 'St. Croix Rods',
  },
  {
    href: 'https://bonafidekayaks.com/',
    label: 'Bonafide Kayaks website',
    img: 'https://images.prismic.io/alexprieu/dfb6912f-f56b-4cfa-a73d-50e47707b228_bonafide-logo-white_uynsad.webp?auto=compress,format',
    alt: 'Bonafide Kayaks',
  },
  {
    href: 'https://luckycraft.com/luckycrafthome/default.htm',
    label: 'Lucky Craft website',
    img: 'https://images.prismic.io/alexprieu/74999daf-2f62-4701-b49b-31e5b9efaeca_lucky_craft_1024x1024_b03aaf.webp?auto=compress,format',
    alt: 'Lucky Craft',
  },
  {
    href: 'https://bullshad.com/',
    label: 'Bullshad website',
    img: 'https://images.prismic.io/alexprieu/8eb97ab6-7c8f-489b-a879-1bfbc4b762cd_bullshad_htjexc.webp?auto=compress,format',
    alt: 'Bullshad swimbaits',
  },
];
---

<section class="sponsors">
  <div class="container">
    <div class="top">
      <h2>Our Sponsors</h2>
      <p class="note">Brands we trust on moving water.</p>
    </div>
    <div class="grid">
      {sponsors.map((s) => (
        <a class="tile" href={s.href} aria-label={s.label} target="_blank" rel="noreferrer">
          <Image src={s.img} alt={s.alt} width={240} height={160} format="webp" loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .sponsors {
    padding: 3rem 0 4rem;
    background:
      radial-gradient(900px circle at 20% 0%, rgba(11, 79, 108, 0.28), transparent 56%),
      radial-gradient(900px circle at 90% 10%, rgba(20, 92, 66, 0.28), transparent 56%),
      linear-gradient(180deg, rgba(11, 18, 32, 0.96), rgba(11, 18, 32, 0.9));
    color: var(--footer-text);
  }

  .top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  h2 {
    font-size: 1.6rem;
    margin: 0;
  }

  .note {
    margin: 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .tile {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
  }

  .tile:hover {
    filter: brightness(1.06);
  }

  @media (max-width: 700px) {
    .top {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 420px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
