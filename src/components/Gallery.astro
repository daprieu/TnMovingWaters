---
import { Image } from 'astro:assets';

export interface Props {
  images: { src: string; alt: string }[];
  heading?: string;
}

const { images, heading = 'Gallery' } = Astro.props;
---

<section class="gallery" aria-label={heading}>
  <div class="container">
    <h2>{heading}</h2>
    <div class="grid">
      {images.map((img, i) => (
        <div class="tile" style={`--d:${i * 60}ms`}>
          <Image src={img.src} alt={img.alt} width={900} height={720} format="webp" loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    padding: 0 0 5rem;
  }

  h2 {
    font-size: var(--step-2);
    margin-bottom: 1.1rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 1rem;
  }

  .tile {
    grid-column: span 4;
    border-radius: var(--radius-3);
    overflow: hidden;
    border: 1px solid rgba(11, 18, 32, 0.12);
    box-shadow: var(--shadow-1);
    animation: reveal 650ms ease both;
    animation-delay: var(--d);
    background: rgba(255, 255, 255, 0.7);
  }

  .tile :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 980px) {
    .tile {
      grid-column: span 6;
    }
  }

  @media (max-width: 600px) {
    .tile {
      grid-column: span 12;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tile {
      animation: none;
    }
  }
</style>
