---
export interface Props {
  title: string;
  body: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title,
  body,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="cta">
  <div class="container inner card reveal">
    <div class="copy">
      <h2>{title}</h2>
      <p>{body}</p>
    </div>
    <div class="actions">
      <a class="btn btn--primary" href={primaryHref}>{primaryLabel}</a>
      {secondaryHref && secondaryLabel ? (
        <a class="btn btn--ghost" href={secondaryHref}>{secondaryLabel}</a>
      ) : null}
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 4rem 0;
  }

  .inner {
    padding: 1.5rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    border-radius: 22px;
    background:
      radial-gradient(900px circle at 15% 20%, rgba(11, 79, 108, 0.14), transparent 55%),
      radial-gradient(900px circle at 90% 10%, rgba(20, 92, 66, 0.14), transparent 55%),
      rgba(255, 255, 255, 0.8);
  }

  h2 {
    font-size: var(--step-2);
    margin-bottom: 0.35rem;
  }

  p {
    color: var(--color-muted);
    margin: 0;
  }

  .actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  @media (max-width: 860px) {
    .inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .actions {
      justify-content: flex-start;
    }
  }
</style>
