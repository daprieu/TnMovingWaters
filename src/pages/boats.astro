---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTA from '../components/CTA.astro';
import { Image } from 'astro:assets';

const heroImage =
  'https://images.prismic.io/alexprieu/d79cce5c-a531-4bc8-a2ac-27a0204c3800_b1_da3elq.jpg?auto=compress,format';
---

<BaseLayout
  title="Tennessee Moving Waters Boats"
  description="Availble boats to use in our selected guide services."
>
  <Hero
    eyebrow="Gear"
    title="Boats & Kayaks"
    lead="From skinny-water floats to big-river runs, we match the craft to the conditions."
    imageSrc={heroImage}
    imageAlt="Jet boat on a river"
    primaryCta={{ href: '/fishing-trip-options', label: 'See Trip Options', variant: 'primary' }}
    secondaryCta={{ href: '/contact-us', label: 'Ask about availability', variant: 'ghost' }}
    stats={['Jet-powered jonboat', 'Stable river kayaks', 'Comfortable setups']}
  />

  <section class="section">
    <div class="container boats-container">
      <h2 class="pageTitle">Our Fleet</h2>

      <section class="boats card reveal">
        <div class="copy">
          <h2>Jonboat</h2>
          <p>2021 G3 1860 Center console tunnel hull with 80hp jet outboard</p>
        </div>
        <div class="image">
          <Image
            src="https://images.prismic.io/alexprieu/d79cce5c-a531-4bc8-a2ac-27a0204c3800_b1_da3elq.jpg?auto=compress,format"
            alt="jonboat"
            width={980}
            height={720}
            format="webp"
            loading="lazy"
            decoding="async"
          />
        </div>
      </section>

      <section class="boats card reveal">
        <div class="copy">
          <h2>Kayaks</h2>
          <p>
            Bonafide RS117 and SS127
            <br />
            The ultimate moving water fishing kayaks. Super stable and very comfortable.
          </p>
        </div>
        <div class="image">
          <Image
            src="https://images.prismic.io/alexprieu/e214c87c-7cfd-4c59-9b10-4b8a07a834ee_b2_bnjjgb.jpg?auto=compress,format"
            alt="kayaks"
            width={980}
            height={720}
            format="webp"
            loading="lazy"
            decoding="async"
          />
        </div>
      </section>
    </div>
  </section>

  <CTA
    title="Want a boat trip or a kayak float?"
    body="Tell us what you want to target and your dates. We'll line up the right water and the right setup."
    primaryHref="/contact-us"
    primaryLabel="Contact Us"
    secondaryHref="/fishing-trip-options"
    secondaryLabel="Trip Options"
  />
</BaseLayout>

<style>
  .boats-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    margin: 0 auto;
    padding: 0;
    width: 100%;
    gap: 2rem;
  }

  .pageTitle {
    font-size: var(--step-2);
  }

  .boats {
    display: flex;
    gap: 2rem;
    padding: 1.25rem;
    text-align: left;
    border-radius: 22px;
    width: 100%;
    align-items: center;
  }

  .copy {
    flex: 1;
  }

  .image {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .image :global(img) {
    width: 100%;
    height: auto;
    border-radius: 16px;
    border: 1px solid rgba(11, 18, 32, 0.1);
  }

  @media only screen and (max-width: 600px) {
    .boats {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
